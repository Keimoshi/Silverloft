# Copy this file to .env for local development. Do not commit real .env files.

# OpenDesign daemon/admin
OD_DAEMON_URL=http://127.0.0.1:7456
OD_ADMIN_TOKEN=replace-with-local-admin-token

# Image generation script/provider. Use your own provider base URL locally.
GPT2IMAGE_BASE_URL=https://provider.example.invalid
GPT2IMAGE_ENDPOINT=https://provider.example.invalid/v1/images/generations
GPT2IMAGE_API_KEY=replace-with-local-key
GPT2IMAGE_ENV_FILE=

# Volcengine/Ark-compatible video and image generation.
ARK_BASE_URL=https://provider.example.invalid/api/v3
ARK_API_KEY=replace-with-local-key

# OpenDesign integrated media provider base URLs.
OD_OPENAI_BASE_URL=https://provider.example.invalid/v1
OPENAI_BASE_URL=https://provider.example.invalid/v1
OD_VOLCENGINE_BASE_URL=https://provider.example.invalid/api/v3
OD_GROK_BASE_URL=https://provider.example.invalid/v1
OD_MINIMAX_BASE_URL=https://provider.example.invalid/v1
OD_FISHAUDIO_BASE_URL=https://provider.example.invalid

# Optional skill-specific model endpoints.
FAL_IMAGE_ENDPOINT=https://provider.example.invalid/openai/gpt-image-2

# Optional local resource downloader.
RES_DOWNLOADER_ENDPOINT=http://127.0.0.1:8899

# Legacy waiting-room script inputs.
WAITING_ROOM_FIRST_FRAME=./assets/first-frame.png
WAITING_ROOM_OUTPUT=./outputs/waiting-room.mp4
